rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /scores/{scoreId} {
      // Herkes liderboard'u okuyabilir
      allow read: if true;

      // Sadece oturum açmış kullanıcılar, geçerli skor aralığıyla yeni kayıt ekleyebilir
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid

        // puan: 0–12000 arası integer
        && request.resource.data.puan is int
        && request.resource.data.puan >= 0
        && request.resource.data.puan <= 12000

        // dogru cevap sayısı: 0–toplam arası
        && request.resource.data.dogru is int
        && request.resource.data.dogru >= 0
        && request.resource.data.dogru <= request.resource.data.toplam

        // toplam soru sayısı: 1–20 arası
        && request.resource.data.toplam is int
        && request.resource.data.toplam >= 1
        && request.resource.data.toplam <= 20

        // isim: max 50 karakter string
        && request.resource.data.isim is string
        && request.resource.data.isim.size() <= 50

        // zorluk: sadece izinli değerler
        && request.resource.data.zorluk in ['kolay', 'orta', 'zor']

        // Sunucu timestamp zorunlu (client timestamp kabul edilmez)
        && request.resource.data.tarih == request.time;

      // Güncelleme ve silme yasak
      allow update, delete: if false;
    }

    match /rooms/{roomId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.ev_sahibi.uid == request.auth.uid;
      allow update: if request.auth != null
        && (resource.data.ev_sahibi.uid == request.auth.uid
          || resource.data.rakip.uid == request.auth.uid);
      allow delete: if false;
    }

    match /seasons/{seasonId}/scores/{scoreId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.puan is int
        && request.resource.data.puan >= 0
        && request.resource.data.puan <= 12000
        && request.resource.data.isim is string
        && request.resource.data.isim.size() <= 50;
      allow update, delete: if false;
    }

    // Diğer tüm koleksiyonlar varsayılan olarak kapalı
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
